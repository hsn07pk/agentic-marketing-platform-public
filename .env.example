# =============================================================================
# Agentic AI Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ONLY infrastructure secrets belong here.  Everything else (feature flags,
# API keys, thresholds, LLM settings, …) is managed through the Configuration
# Service (Dashboard → Operations → Configuration) which stores values in the
# database with optional encryption for secrets.
#
# .env is gitignored and will not be committed.
# =============================================================================

# --- Database (required — used by PostgreSQL container at startup) ---
POSTGRES_DB=agentic
POSTGRES_USER=agentic
POSTGRES_PASSWORD=changeme

# --- Security (required — used for JWT / encryption before DB is available) ---
SECRET_KEY=change-me-to-a-random-string

# --- Monitoring (required — Grafana container reads these at first boot) ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme
